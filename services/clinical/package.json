{
  "name": "@saas/clinical",
  "version": "0.1.0",
  "private": true,
  "description": "Clinical service (patients, encounters, notes) for dental-saas platform.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "RUN_INTEGRATION_TESTS=true vitest run src/__tests__/integration"
  },
  "dependencies": {
    "@saas/config": "workspace:*",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.7.2",
    "@types/pg": "^8.20.0",
    "pg": "^8.16.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
