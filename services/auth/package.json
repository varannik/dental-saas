{
  "name": "@saas/auth",
  "version": "0.1.0",
  "private": true,
  "description": "Authentication service for dental-saas platform.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:integration": "RUN_INTEGRATION_TESTS=true vitest run src/__tests__/integration/auth.integration.test.ts",
    "test:contract": "RUN_INTEGRATION_TESTS=true vitest run src/__tests__/integration/auth.contract.test.ts",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:contract"
  },
  "dependencies": {
    "@saas/config": "workspace:*",
    "@saas/types": "workspace:*",
    "@saas/utils": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "bcryptjs": "^3.0.2",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.1",
    "ioredis": "^5.8.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
