# ============================================================================
# Dental SaaS Platform - Environment Variables
# ============================================================================
# Copy this file to .env.local (or .env) and update values for your environment.
# Never commit real secrets.

# ----------------------------------------------------------------------------
# Core App
# ----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug
PORT=4000
APP_PORT=3000
API_GATEWAY_PORT=4000

# ----------------------------------------------------------------------------
# Web / Test Targets
# ----------------------------------------------------------------------------
BASE_URL=http://localhost:3000
TEST_API_URL=http://localhost:3001
CI=false
DEBUG=0

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=dental_saas
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dental_saas

# Script helpers (legacy naming used by scripts)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dental_saas
DB_USER=postgres
DB_PASSWORD=postgres

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# Optional: Sentinel / tests
SENTINEL_PASSWORD=
REDIS_TEST_HOST=localhost
REDIS_TEST_PORT=6379

# ----------------------------------------------------------------------------
# Auth / Session / Security
# ----------------------------------------------------------------------------
JWT_SECRET=change-me-development-only-min-32-characters
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
JWT_ISSUER=dental-saas
FIELD_ENCRYPTION_KEY=change-me-32+chars-for-field-encryption

# ----------------------------------------------------------------------------
# AI / Voice
# ----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# ----------------------------------------------------------------------------
# Storage (MinIO/S3)
# ----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=dental-saas-local
S3_REGION=eu-central-1

# ----------------------------------------------------------------------------
# AWS / LocalStack / Infra
# ----------------------------------------------------------------------------
AWS_PROFILE=default
AWS_REGION=eu-central-1
AWS_DEFAULT_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
LOCALSTACK_ENDPOINT=http://localhost:4566

# ----------------------------------------------------------------------------
# Payments / Email
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SMTP_USER=
SMTP_PASS=

# ----------------------------------------------------------------------------
# Monitoring / Observability
# ----------------------------------------------------------------------------
SENTRY_DSN=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=dental-saas
