{
  "name": "@saas/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared domain and transport types for dental-saas services.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "src"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./tenancy": "./src/tenancy.ts",
    "./tenancy-governance": "./src/tenancy-governance.ts",
    "./clinical": "./src/clinical.ts",
    "./clinical-context": "./src/clinical-context.ts",
    "./procedures-ai-governance": "./src/procedures-ai-governance.ts",
    "./imaging": "./src/imaging.ts",
    "./integrations": "./src/integrations.ts",
    "./voice": "./src/voice.ts",
    "./agent": "./src/agent.ts",
    "./billing": "./src/billing.ts",
    "./billing-operations": "./src/billing-operations.ts",
    "./knowledge-communication": "./src/knowledge-communication.ts",
    "./compliance": "./src/compliance.ts",
    "./reference": "./src/reference.ts",
    "./extensibility": "./src/extensibility.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "echo \"@saas/types is source-only; no build step\"",
    "clean": "echo \"nothing to clean\"",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit --module ESNext --moduleResolution Bundler --target ES2022 --strict src/*.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
